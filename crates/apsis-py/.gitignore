# Build artefacts produced by `maturin develop` and `maturin build`.
# The compiled extension (`_native.pyd` on Windows, `_native.so`
# elsewhere) and the bytecode caches are reproducible from source on
# every machine; checking them in would surface spurious diff noise
# on every contributor's first build.

**/__pycache__/
**/*.pyc
*.pyd
*.so
*.dylib

# Editable-install metadata produced by `pip install -e .` /
# `maturin develop`.
*.egg-info/
dist/
build/

# Local virtual envs created inside the crate (CI uses workspace-root
# .venv, which is already ignored at the workspace level).
.venv/

# Pytest / mypy / ruff caches (also ignored workspace-wide if the
# root .gitignore lists them, but kept here so the crate is
# self-contained).
.pytest_cache/
.mypy_cache/
.ruff_cache/
