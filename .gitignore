/target
.venv

# Maturin-built extension modules (output of `maturin develop`).
apsis/*.pyd
apsis/*.so
apsis/*.dylib

# Python bytecode caches.
__pycache__/
*.pyc
*.pyo

# Editor / IDE config.
.vscode/

# Runtime record files (apsis-record binary format).
*.apsis

# Compiled paper (generated via `make paper`). Figures under
# `paper/figures/` are versioned; the assembled paper.pdf is not.
/paper.pdf
